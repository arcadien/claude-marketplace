---
import Layout from '../../layouts/Layout.astro';
import registry from '../../data/registry.json';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = () => {
  return registry.plugins.map((plugin) => ({
    params: { name: plugin.name },
    props: { plugin },
  }));
};

interface Props {
  plugin: (typeof registry.plugins)[number];
}
const { plugin } = Astro.props;
const base = (Astro.site ?? '') + import.meta.env.BASE_URL;
const marketplaceUrl = new URL('marketplace.json', base).href;
---
<Layout title={plugin.name}>
  <h1>
    {plugin.name}
    <small style="font-size: 0.75em; color: #6b7280;"> v{plugin.version}</small>
  </h1>
  <p style="color: #4b5563; margin: 0.5rem 0 1.5rem;">{plugin.description}</p>
  <p style="margin-bottom: 1.5rem;">Auteur : <strong>{plugin.author}</strong></p>

  <h2 style="font-size: 1.1rem; margin-bottom: 0.5rem;">Installation</h2>
  <p style="color: #6b7280; margin-bottom: 0.5rem; font-size: 0.9rem;">1. Ajouter le marketplace (une seule fois) :</p>
  <pre style="background: #f3f4f6; padding: 1rem; border-radius: 6px; overflow-x: auto; margin-bottom: 1rem;"><code>/plugin marketplace add {marketplaceUrl}</code></pre>
  <p style="color: #6b7280; margin-bottom: 0.5rem; font-size: 0.9rem;">2. Installer le plugin :</p>
  <pre style="background: #f3f4f6; padding: 1rem; border-radius: 6px; overflow-x: auto;"><code>/plugin install {plugin.name}@arcadien-plugins</code></pre>
</Layout>
